# ─────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────

# Telegram Bot — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM Configuration — OpenRouter (primary)
LLM_API_KEY=your_openrouter_api_key
LLM_MODEL=google/gemini-2.0-flash-001
LLM_BASE_URL=https://openrouter.ai/api/v1

# Celo Blockchain
CELO_PRIVATE_KEY=your_wallet_private_key
AGENT_WALLET_ADDRESS=your_agent_wallet_address
CELO_RPC_URL=https://forno.celo.org

# Reloadly — airtime, data, bills, gift cards across 170+ countries
# Get credentials at https://www.reloadly.com/developers
RELOADLY_CLIENT_ID=your_reloadly_client_id
RELOADLY_CLIENT_SECRET=your_reloadly_client_secret

# MongoDB — wallet persistence, conversation history, groups
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/toppa

# Wallet Encryption — 32-byte hex key for AES-256-GCM
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=your_64_char_hex_key_here

# ─────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────

# Environment
NODE_ENV=development
PORT=3000

# ERC-8004 Agent Identity
AGENT_ID=1870
ERC8004_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432

# API Configuration
API_URL=http://localhost:3000

# Fallback LLM — auto-switches on timeout/rate-limit
# FALLBACK_LLM_MODEL=meta-llama/llama-3.3-70b-instruct
# FALLBACK_LLM_KEY=             # Uses LLM_API_KEY if not set
# FALLBACK_LLM_BASE_URL=        # Uses LLM_BASE_URL if not set

# Voice Transcription — Deepgram (for Telegram/WhatsApp voice notes)
# Get a free key at https://console.deepgram.com
# DEEPGRAM_API_KEY=your_deepgram_api_key

# WhatsApp Bot — prints QR code on startup for pairing
# ENABLE_WHATSAPP=true

# Admin API — protects /admin/* endpoints
# ADMIN_API_KEY=your_secure_admin_key

# Prestmit — gift card sell pipeline (coming soon)
# PRESTMIT_API_KEY=
# PRESTMIT_API_SECRET=
# PRESTMIT_WEBHOOK_SECRET=

# Reloadly Sandbox — used when NODE_ENV !== 'production'
# RELOADLY_CLIENT_ID_SANDBOX=
# RELOADLY_CLIENT_SECRET_SANDBOX=

# CORS — comma-separated allowed origins
# ALLOWED_ORIGINS=https://toppa.cc,https://app.toppa.cc

# IPFS Gateway — for ERC-8004 metadata uploads
# IPFS_GATEWAY=https://ipfs.toppa.cc

# Self Protocol — ZK verification (optional)
# SELFCLAW_API_KEY=
# SELFCLAW_APP_ID=
# SELF_APP_SCOPE=

# Auto-reputation — submit on-chain reviews after purchases
# AUTO_REPUTATION_ENABLED=true

# Heartbeat LLM — separate model for proactive check-ins
# HEARTBEAT_MODEL=gpt-4o-mini
