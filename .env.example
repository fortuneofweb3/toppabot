# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM Configuration — OpenRouter (primary)
LLM_API_KEY=your_openrouter_api_key
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
LLM_BASE_URL=https://openrouter.ai/api/v1

# Fallback LLM (auto-switches on timeout/rate-limit, uses same key by default)
# Default fallback: deepseek/deepseek-chat via OpenRouter (~$0.0003/req)
# FALLBACK_LLM_MODEL=deepseek/deepseek-chat

# Celo Blockchain (Mainnet)
CELO_RPC_URL=https://forno.celo.org
CELO_PRIVATE_KEY=your_wallet_private_key
AGENT_WALLET_ADDRESS=your_agent_wallet_address

# ERC-8004 Identity
ERC8004_REGISTRY_ADDRESS=0x...
AGENT_ID=1

# API Configuration
API_URL=http://localhost:3000
ALLOWED_ORIGINS=https://toppa.cc,https://app.toppa.cc

# Reloadly (airtime, bills, gift cards — 170+ countries)
# Get credentials at https://www.reloadly.com/developers
RELOADLY_CLIENT_ID=your_reloadly_client_id
RELOADLY_CLIENT_SECRET=your_reloadly_client_secret

# MongoDB (wallet persistence, conversation history)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/toppa

# Wallet Encryption (for Telegram in-app wallets)
WALLET_ENCRYPTION_KEY=your_random_secret_at_least_32_chars

# Environment
NODE_ENV=development
PORT=3000

# Voice Transcription (Deepgram — for Telegram voice notes)
# Get a free key at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key

# WhatsApp Bot
ENABLE_WHATSAPP=true
