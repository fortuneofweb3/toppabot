# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM Configuration (DeepSeek recommended - 97% cheaper than OpenAI)
OPENAI_API_KEY=your_deepseek_api_key
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# Celo Blockchain (Mainnet)
CELO_RPC_URL=https://forno.celo.org
CELO_PRIVATE_KEY=your_wallet_private_key
AGENT_WALLET_ADDRESS=your_agent_wallet_address

# ERC-8004 Identity
ERC8004_REGISTRY_ADDRESS=0x...
AGENT_ID=jara-agent

# Thirdweb (for x402 and blockchain interactions)
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key_from_dashboard

# x402 Payment Protocol
X402_ENABLED=true
X402_FEE_AMOUNT=0.5

# SelfProtocol (Human Verification)
SELFCLAW_API_KEY=your_selfclaw_api_key
SELFCLAW_APP_ID=your_app_id

# Reloadly (airtime, bills, gift cards — 170+ countries)
# Get credentials at https://www.reloadly.com/developers
RELOADLY_CLIENT_ID=your_reloadly_client_id
RELOADLY_CLIENT_SECRET=your_reloadly_client_secret

# Environment
NODE_ENV=development
PORT=3000
